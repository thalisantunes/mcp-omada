# Copy this file to .env and adjust as needed. Never commit the real .env.

# Base URL of the Omada controller (OC200, software controller, etc), e.g.
# https://192.168.1.2:8043 - no trailing slash. Required.
OMADA_BASE_URL=https://192.168.1.2:8043

# Omada Controller ID (the "omadacId" every /api/v2 and /openapi/v1 path is
# scoped under). Optional - auto-discovered via the unauthenticated GET
# /api/info endpoint if left unset.
OMADA_OMADAC_ID=

# Site ID to operate on. Optional - auto-selected if the controller has
# exactly one site (requires legacy auth to discover; see README "Verified
# against real hardware"). Required if the controller manages more than one
# site, or if only Open API credentials are configured.
OMADA_SITE_ID=

# --- Authentication: choose ONE of the two credential pairs below --------
#
# Option A - legacy local-user login (preferred: richer field set, the only
# path list_sites/get_wifi_summary/get_clients/get_alerts/set_radio_channel
# work through - see README).
OMADA_USER=
OMADA_PASS=
#
# Option B - Open API client_credentials (Global View > Settings > Platform
# Integration > Open API, mode Client, role Viewer). Reduced field set - see
# README's auth x endpoint matrix.
OMADA_CLIENT_ID=
OMADA_CLIENT_SECRET=

# Verify the controller's TLS certificate. Defaults to false with a startup
# warning: an OC200 in LAN commonly serves a self-signed certificate on its
# management port, so strict verification would refuse to connect out of the
# box. Set to true (and configure a CA trust store, if needed) once the
# controller has a certificate you can actually validate.
OMADA_VERIFY_TLS=false

# HTTP request timeout, in seconds.
OMADA_TIMEOUT=15

# Log level for the server process (stderr; stdout is reserved for the MCP
# stdio transport).
OMADA_LOG_LEVEL=INFO

# Read-only by default. Set to true only when you intend to use write tools
# (currently just set_radio_channel). See README "Security model".
OMADA_ALLOW_WRITE=false

# File path for the write audit journal (one JSON line per guarded write
# call - preview/applied/rejected/error, never a credential). Optional -
# if unset, the same events are logged as plain INFO lines to stderr
# instead. See README "Security model" and docs/api-notes.md.
OMADA_AUDIT_LOG=
